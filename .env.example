# ===========================
# Database Configuration
# ===========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openclaw
DB_USER=postgres
DB_PASSWORD=change-me-in-production

# ===========================
# Redis Configuration
# ===========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me-in-production

# ===========================
# JWT Configuration
# ===========================
JWT_SECRET=change-me-in-production-use-a-secure-random-string
JWT_EXPIRES_IN=24h

# ===========================
# Service Ports
# ===========================
AUTH_PORT=3001
INSTANCE_PORT=3002
WEB_PORT=3000

# ===========================
# Logging Configuration
# ===========================
LOG_LEVEL=info
LOG_DIR=logs
SERVICE_NAME=openclaw

# ===========================
# Environment
# ===========================
NODE_ENV=development

# ===========================
# Plan Limits (for SaaS mode)
# ===========================
# community: max 10 instances
# professional: max 50 instances
# enterprise: max 200 instances
